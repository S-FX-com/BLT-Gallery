{
    "name": "s-fx-com/zymgallery",
    "description": "A modern, self-contained WordPress photo gallery plugin with AWS S3/CloudFront offloading and WebP image optimization.",
    "license": "GPL-3.0-or-later",
    "type": "wordpress-plugin",
    "authors": [
        {
            "name": "ZymGallery Contributors"
        }
    ],
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.300"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "ZymGallery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZymGallery\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress src/",
        "test": "phpunit --testdox"
    }
}
