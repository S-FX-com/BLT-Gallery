{
    "name": "@s-fx-com/zymgallery",
    "version": "2.0.0",
    "description": "ZymGallery WordPress plugin – build scripts",
    "private": true,
    "license": "GPL-3.0-or-later",
    "scripts": {
        "build": "wp-scripts build --config webpack.config.js",
        "start": "wp-scripts start --config webpack.config.js",
        "lint:js": "wp-scripts lint-js assets/src",
        "lint:css": "wp-scripts lint-style assets/src",
        "lint": "npm run lint:js && npm run lint:css",
        "format": "wp-scripts format assets/src"
    },
    "devDependencies": {
        "@wordpress/scripts": "^27.9"
    }
}
